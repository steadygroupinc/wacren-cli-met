# Contact Form SMTP Configuration
# Replace these with your actual SMTP credentials

SMTP_HOST=smtp.wacren.net
SMTP_PORT=587
SMTP_USER=climet@wacren.net
SMTP_PASS=your-app-specific-password

# Optional: Configuration for the sender name/email
